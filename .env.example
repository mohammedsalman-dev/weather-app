####################################
# 🌐 DATABASE CONFIGURATION
####################################

# MySQL database host (use 127.0.0.1 or localhost)
DB_HOST=localhost

# MySQL username
DB_USER=root

# MySQL password (wrap special characters in double quotes if needed)
DB_PASSWORD="your_db_password"

# Name of the database to connect to
DB_NAME=weather_app_db

####################################
# 🚀 APPLICATION SETTINGS (optional)
####################################

# Port the server runs on (default is 3000)
PORT=3000

####################################
# 🔐 API KEYS (Do NOT hardcode in codebase)
####################################

# Mapbox API Key (used for geocoding addresses)
MAPBOX_API_KEY=your_mapbox_api_key

# OpenWeatherMap API Key (used for weather data)
OPENWEATHER_API_KEY=your_openweather_api_key

##############################
# 🌍 Base URLs
##############################

MAPBOX_BASE_URL=https://api.mapbox.com
OPENWEATHER_BASE_URL=https://api.openweathermap.org
