####################################
# 🌐 DATABASE CONFIGURATION
####################################

# Host where your MySQL database is running (usually localhost or 127.0.0.1)
DB_HOST=localhost

# MySQL username
DB_USER=root

# MySQL password (use strong password in production)
DB_PASSWORD=your_password_here

# Database name to be used by the app
DB_NAME=weather_app_db

####################################
# 🔐 API KEYS (Do NOT hardcode in codebase)
####################################

# API keys will be stored in DB, but you can add temporary values here for local use (optional)

# MAPBOX API KEY (for geocoding address to lat/lon)
# MAPBOX_API_KEY=your_mapbox_api_key_here

# OPENWEATHERMAP API KEY (for fetching weather data)
# OPENWEATHER_API_KEY=your_openweathermap_api_key_here

####################################
# 🚀 APP SETTINGS
####################################

# Port to run the application on (default is 3000)
PORT=3000


##############################
# 🌍 Base URLs
##############################

MAPBOX_BASE_URL=https://api.mapbox.com
OPENWEATHER_BASE_URL=https://api.openweathermap.org