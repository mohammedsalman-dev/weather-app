<!DOCTYPE html>
<html lang="en">
   <head>
      <meta charset="UTF-8">
      <title>Weather App</title>
      <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
      <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css" />
      <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
   </head>
   <body class="bg-light">
      <div class="container mt-5">
         <h1 class="mb-4">🌤 Weather Finder</h1>
         <div class="form-group">
            <input type="text" id="addressInput" class="form-control" placeholder="Enter address..." />
         </div>
         <button id="searchBtn" class="btn btn-primary">🔍 Get Weather</button>
         <button id="saveBtn" class="btn btn-success" disabled>💾 Save Weather</button>
         <button id="historyBtn" class="btn btn-secondary">📜 Show History</button>
         <hr />
         <div id="resultContainer" class="mt-4"></div>
         <div id="historyContainer" class="mt-5"></div>
      </div>
      <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
      <script src="/main.js"></script>
   </body>
</html>